{
	"name": "later-queue",
	"version": "0.1.0",
	"description": "Offline-first client-side task queue — persist, retry, and replay async tasks",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"scripts": {
		"build": "tsup",
		"lint": "biome lint ./src",
		"format": "biome format ./src --write",
		"check": "biome check ./src",
		"prepublishOnly": "bun run check && bun run build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@changesets/cli": "^2.31.0",
		"@types/bun": "latest",
		"lefthook": "^2.1.6",
		"tsup": "^8.5.1"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"author": {
		"name": "dongnez"
	},
	"keywords": [
		"queue",
		"offline",
		"tasks",
		"offline-first",
		"react-native",
		"react"
	],
	"license": "MIT"
}
